<script>
$(function(){

/* ════ IMAGES (embedded base64) ════ */
var IMG = {
  me:  'data:image/jpeg;base64,',
  ms1: 'data:image/jpeg;base64,',
  ms2: 'data:image/jpeg;base64,',
  ms3: 'data:image/jpeg;base64,',
  ms4: 'data:image/jpeg;base64,',
  ms5: 'data:image/jpeg;base64,'
};

/* ════ PIN AUTH ════ */
var OWNER_PIN = loadLS('owner_pin', '1234');
var isOwner   = false;
var pinBuffer = [];
var pinMode   = 'login'; // 'login' | 'change'

function loadLS(k,def){try{var v=localStorage.getItem('pcto_'+k);return v?JSON.parse(v):def}catch(e){return def}}
function saveLS(k,v){try{localStorage.setItem('pcto_'+k,JSON.stringify(v))}catch(e){}}

$('#lock-btn').on('click',function(){
  if(isOwner){ logout(); return; }
  pinMode='login';
  $('#auth-mode-title').text('Accesso proprietario');
  $('#auth-mode-sub').text('Inserisci il PIN a 4 cifre per modificare il portfolio.');
  pinBuffer=[]; updatePinDisplay();
  $('#modal-auth').addClass('open');
});
$('#auth-close').on('click',function(){ $('#modal-auth').removeClass('open'); });

$(document).on('click','.pin-key',function(){
  var d=$(this).data('d');
  if(pinBuffer.length>=4) return;
  pinBuffer.push(String(d));
  updatePinDisplay();
  if(pinBuffer.length===4) setTimeout(checkPin,150);
});
$('#pin-del').on('click',function(){ pinBuffer.pop(); updatePinDisplay(); });

function updatePinDisplay(){
  for(var i=0;i<4;i++){
    var $d=$('#pd'+i);
    if(i<pinBuffer.length){ $d.text('●').addClass('filled'); }
    else{ $d.text('·').removeClass('filled'); }
  }
  $('#pin-error').text('');
}

function checkPin(){
  var entered=pinBuffer.join('');
  if(pinMode==='login'){
    if(entered===OWNER_PIN){
      isOwner=true;
      $('body').addClass('owner-mode');
      $('#lock-btn').addClass('unlocked').html('🔓 Proprietario');
      $('#modal-auth').removeClass('open');
      toast('Modalità proprietario attiva!');
    } else {
      $('#pin-error').text('PIN errato. Riprova.');
      pinBuffer=[];
      updatePinDisplay();
    }
  }
}

function logout(){
  isOwner=false;
  $('body').removeClass('owner-mode');
  $('#lock-btn').removeClass('unlocked').html('🔒 Proprietario');
  toast('Uscito dalla modalità proprietario.');
}

/* ════ DEFAULT DATA ════ */
var DEF_PROFILE={
  name:'Yeabsira Galaverni',
  school:'I.I.S. Blaise Pascal — Indirizzo Informatico',
  bio:'Sono uno studente appassionato di tecnologia e informatica. Mi piace il mondo software e continuo a imparare nuove tecnologie ogni giorno.',
  skills:['C++','HTML','CSS','Assembly'],
  initials:'YG',
  usePhoto:true
};
var DEF_PRESETS={
  terza:[
    {icon:'📋',name:'Progetto UST',desc:'Lezione introduttiva, comune a tutti gli indirizzi, sui contenuti del percorso PCTO attivato dal Ministero della Pubblica Istruzione.',ore:'',ente:'Ministero MPI',ctra:'Ascolto attivo, Orientamento',cspec:'Conoscenza normativa PCTO',imgs:[]},
    {icon:'🦺',name:'Progetto Sicurezza',desc:'Modulo sulla sicurezza nei luoghi di lavoro e per le attività laboratoriali. Le lezioni sono tenute dai professori di Informatica e di Telecomunicazioni.',ore:'',ente:'I.I.S. Blaise Pascal',ctra:'Rispetto delle norme, Responsabilità',cspec:'D.Lgs 81/2008, Sicurezza laboratori',imgs:[]},
    {icon:'🚌',name:'Progetto BUSCONNECT',desc:"Attività di formazione digitale tenuta dagli studenti delle classi terze, rivolta a pensionati, anziani, studenti di scuola media e disabili. Gli studenti si sono occupati della preparazione e della gestione delle singole lezioni.",ore:'',ente:'Comune di Parma',ctra:'Comunicazione, Empatia, Insegnamento tra pari',cspec:'Alfabetizzazione digitale, Didattica',imgs:[]},
    {icon:'🖥️',name:'Progetto Monta&Smonta',desc:"Analisi del contenuto hardware di un PC e di tutte le sue componenti. A piccolo gruppo gli studenti si sono occupati di disassemblare e ri-assemblare un PC, identificando e catalogando tutti i suoi componenti.",ore:'',ente:'I.I.S. Blaise Pascal',ctra:'Lavoro di squadra, Problem solving',cspec:'Hardware PC, CPU, RAM, HDD, Scheda madre',imgs:['ms1','ms2','ms3','ms4','ms5']},
    {icon:'🌐',name:'Progetto Portfolio',desc:"Realizzazione, aggiornamento e conclusione di un sito web contenente i materiali e le descrizioni delle diverse attività di PCTO svolte durante l'anno scolastico corrente.",ore:'',ente:'I.I.S. Blaise Pascal',ctra:'Autonomia, Organizzazione',cspec:'HTML, CSS, JavaScript, Web Design',imgs:[]}
  ],
  quarta:[
    {icon:'🏢',name:'Project work CONFINDUSTRIA',desc:'',ore:'',ente:'Confindustria',ctra:'',cspec:'',imgs:[]},
    {icon:'📄',name:'CNA Contratti aziendali',desc:'',ore:'',ente:'CNA',ctra:'',cspec:'',imgs:[]},
    {icon:'⚡',name:'Polarity',desc:'',ore:'',ente:'',ctra:'',cspec:'',imgs:[]},
    {icon:'🌐',name:'Portfolio',desc:'',ore:'',ente:'I.I.S. Blaise Pascal',ctra:'',cspec:'',imgs:[]}
  ],
  quinta:[]
};

/* ════ STATO ════ */
var profile=loadLS('profile',DEF_PROFILE);
var presets=loadLS('presets',DEF_PRESETS);
var added  = {terza:[], quarta:[], quinta:[]};
var currentPage='home';
var detailFrom='home';

/* ════ NAV ════ */
$('.nav-links button').on('click',function(){
  var page=$(this).data('page');
  goPage(page);
  $('.nav-links button').removeClass('active');
  $(this).addClass('active');
});
function goPage(page){
  currentPage=page;
  $('.page').removeClass('visible');
  $('#page-'+page).addClass('visible');
  if(page!=='detail'){
    $('.nav-links button').removeClass('active');
    $('.nav-links button[data-page="'+page+'"]').addClass('active');
  }
}

/* ════ DETAIL ════ */
function openDetail(proj, year){
  detailFrom=currentPage;
  var $cover=$('#detail-cover').empty();
  var coverImgKey = proj.imgs && proj.imgs.length ? proj.imgs[0] : null;
  if(coverImgKey && IMG[coverImgKey]){
    $cover.html('<img src="'+IMG[coverImgKey]+'" alt="">');
  } else {
    $cover.html('<span style="font-size:4rem">'+(proj.icon||'📁')+'</span>');
  }
  $('#detail-title').text(proj.name);
  var badges='<span class="year-badge">'+({terza:'Terza',quarta:'Quarta',quinta:'Quinta'}[year]||year)+'</span>';
  if(proj.ore) badges+='<span class="ore-badge">'+esc(proj.ore)+'h</span>';
  if(proj.ente) badges+='<span class="meta-chip">'+esc(proj.ente)+'</span>';
  $('#detail-badges').html(badges);
  $('#detail-desc').text(proj.desc||'Nessuna descrizione disponibile.');

  // competenze
  var ctra=(proj.ctra||'').split(',').map($.trim).filter(Boolean);
  var cspec=(proj.cspec||'').split(',').map($.trim).filter(Boolean);
  if(ctra.length||cspec.length){
    var html='';
    $.each(ctra,function(_,c){ html+='<div class="comp-item"><strong>Trasversale</strong>'+esc(c)+'</div>'; });
    $.each(cspec,function(_,c){ html+='<div class="comp-item"><strong>Specifica</strong>'+esc(c)+'</div>'; });
    $('#detail-comp-grid').html(html);
    $('#detail-competenze').show();
  } else {
    $('#detail-competenze').hide();
  }

  // gallery
  var imgs=proj.imgs||[];
  if(imgs.length){
    var ghtml='';
    $.each(imgs,function(_,key){
      if(IMG[key]) ghtml+='<img class="gallery-img" src="'+IMG[key]+'" data-src="'+IMG[key]+'" alt="">';
    });
    $('#detail-gallery').html(ghtml);
    $('#detail-gallery-wrap').show();
  } else {
    $('#detail-gallery-wrap').hide();
  }

  $('.nav-links button').removeClass('active');
  goPage('detail');
}

$('#detail-back').on('click',function(){ goPage(detailFrom); });

$(document).on('click','.gallery-img',function(){
  $('#lb-img').attr('src',$(this).data('src'));
  $('#lightbox').addClass('open');
});
$('#lb-close,#lightbox').on('click',function(e){
  if($(e.target).is('#lightbox')||$(e.target).is('#lb-close')) $('#lightbox').removeClass('open');
});

/* ════ PROFILO ════ */
function renderProfile(){
  var p=profile;
  var parts=p.name.split(' ');
  var display=parts.length>=2?parts[0]+'<br>'+parts.slice(1).join(' '):p.name;
  $('#hero-name').html(display);
  $('#hero-school').text(p.school);
  $('#hero-bio').text(p.bio);
  $('#footer-name').text(p.name);
  var $row=$('#hero-skills').empty();
  $.each(p.skills,function(_,s){ $row.append('<span class="skill-tag">'+esc(s)+'</span>'); });
  var $av=$('#hero-avatar').empty();
  if(p.usePhoto!==false && IMG.me){
    $av.html('<img class="avatar-img" src="'+IMG.me+'" alt="'+esc(p.name)+'">');
  } else {
    $av.html('<div class="avatar-initials">'+esc(p.initials||'YG')+'</div>');
  }
  $('#edit-name').val(p.name);
  $('#edit-school').val(p.school);
  $('#edit-bio').val(p.bio);
  $('#edit-skills').val(p.skills.join(', '));
  $('#edit-initials').val(p.initials);
}

$('#open-about-modal').on('click',function(){ if(!isOwner) return; $('#modal-about').addClass('open'); });
$('#modal-close-btn').on('click',function(){ $('#modal-about').removeClass('open'); });
$('#modal-about').on('click',function(e){ if($(e.target).is('#modal-about')) $(this).removeClass('open'); });
$('#save-about-btn').on('click',function(){
  if(!isOwner) return;
  var skills=$('#edit-skills').val().split(',').map($.trim).filter(Boolean);
  profile.name    =$('#edit-name').val().trim()||profile.name;
  profile.school  =$('#edit-school').val().trim()||profile.school;
  profile.bio     =$('#edit-bio').val().trim()||profile.bio;
  profile.skills  =skills.length?skills:profile.skills;
  profile.initials=$('#edit-initials').val().trim()||profile.initials;
  saveLS('profile',profile);
  renderProfile(); renderHomeGrid();
  $('#modal-about').removeClass('open');
  toast('Profilo aggiornato!');
});

/* ════ HOME GRID ════ */
function renderHomeGrid(){
  var $g=$('#home-grid').empty();
  var labels={terza:'Terza',quarta:'Quarta',quinta:'Quinta'};
  $.each(['terza','quarta','quinta'],function(_,year){
    $.each(presets[year].concat(added[year]),function(_,proj){
      var coverHtml='';
      if(proj.imgs&&proj.imgs.length&&IMG[proj.imgs[0]]){
        coverHtml='<img src="'+IMG[proj.imgs[0]]+'" alt="">';
      } else {
        coverHtml='<span>'+(proj.icon||'📁')+'</span>';
      }
      var $c=$('<div class="proj-card" data-year="'+year+'" data-type="'+(_<presets[year].length?'preset':'added')+'" data-idx="'+_+'">'+
        '<div class="proj-img">'+coverHtml+'</div>'+
        '<div class="proj-body">'+
          '<span class="year-badge">'+labels[year]+'</span>'+
          '<h3>'+esc(proj.name)+'</h3>'+
          '<p>'+esc((proj.desc||'').substring(0,80))+(proj.desc&&proj.desc.length>80?'…':'')+'</p>'+
        '</div></div>');
      // store proj data
      $c.data('proj',proj);
      $g.append($c);
    });
  });
  updateStats();
}

$(document).on('click','.proj-card',function(){
  var proj=$(this).data('proj');
  var year=$(this).data('year');
  if(proj&&year) openDetail(proj,year);
});

function updateStats(){
  $('#stat-3').text(presets.terza.length+added.terza.length);
  $('#stat-4').text(presets.quarta.length+added.quarta.length);
}

/* ════ PRESET CARDS ════ */
function renderPresets(year){
  var $g=$('#preset-'+year).empty();
  if(!presets[year].length){
    return;
  }
  $.each(presets[year],function(i,proj){
    var meta='';
    if(proj.ore)  meta+='<span class="meta-chip gold">'+esc(proj.ore)+'h</span>';
    if(proj.ente) meta+='<span class="meta-chip">'+esc(proj.ente)+'</span>';
    var coverThumb='';
    if(proj.imgs&&proj.imgs.length&&IMG[proj.imgs[0]]){
      coverThumb='<img src="'+IMG[proj.imgs[0]]+'" style="width:100%;height:100%;object-fit:cover" alt="">';
    }
    $g.append(
      '<div class="preset-card">'+
        '<div class="preset-card-top">'+
          '<span class="preset-card-icon">'+(coverThumb?'':proj.icon||'📁')+'</span>'+
          '<div class="preset-card-actions">'+
            '<button class="icon-btn view-btn preset-view-btn" data-year="'+year+'" data-idx="'+i+'" title="Dettagli">👁</button>'+
            '<button class="icon-btn preset-edit-btn owner-only-inline" data-year="'+year+'" data-idx="'+i+'" title="Modifica">✏️</button>'+
            '<button class="icon-btn danger preset-del-btn owner-only-inline" data-year="'+year+'" data-idx="'+i+'" title="Elimina">🗑</button>'+
          '</div>'+
        '</div>'+
        '<div class="preset-card-body">'+
          '<div class="preset-card-name">'+esc(proj.name)+'</div>'+
          '<div class="preset-card-desc">'+esc((proj.desc||'').substring(0,100))+(proj.desc&&proj.desc.length>100?'…':'')+'</div>'+
          (meta?'<div class="preset-card-meta">'+meta+'</div>':'')+
        '</div>'+
        '<div class="edit-inline" id="ei-p-'+year+'-'+i+'">'+editFormHtml('ep',year,i,proj)+'</div>'+
      '</div>'
    );
  });
}

$(document).on('click','.preset-view-btn',function(e){
  e.stopPropagation();
  var year=$(this).data('year'),i=$(this).data('idx');
