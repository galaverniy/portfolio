/* ════ UTILS ════ */
function esc(s){ return $('<div>').text(String(s||'')).html(); }
function clearForm(p){
  $('#'+p+'-name,#'+p+'-desc,#'+p+'-ore,#'+p+'-ente,#'+p+'-ctra,#'+p+'-cspec').val('');
  $('#'+p+'-date').val('');
}
var _tt;
function toast(msg){
  $('#toast-msg').text(msg||'Salvato!');
  $('#toast').addClass('show');
  clearTimeout(_tt);
  _tt=setTimeout(function(){ $('#toast').removeClass('show'); },2500);
}
function fmtDate(d){ if(!d) return ''; var p=d.split('-'); return p.length===3?p[2]+'/'+p[1]+'/'+p[0]:d; }

