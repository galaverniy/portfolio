<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Portfolio PCTO — Yeabsira Galaverni</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#0d1321;--bg2:#111827;--surface:#1d2d44;--surface2:#243650;
      --surface3:#2d4060;--border:#2e4060;--border2:#3e5c76;
      --text:#f0ebd8;--muted:#a8b8cc;--hint:#748cab;
      --gold:#c9a84c;--gold2:#e8c97a;--gold-bg:rgba(201,168,76,.1);
      --gold-border:rgba(201,168,76,.3);
      --accent:#748cab;--accent2:#f0ebd8;
      --red:#e05c5c;--green:#5cb88a;--blue:#748cab;
      --radius:10px;--radius-lg:16px;--radius-xl:22px;
    }
    html{scroll-behavior:smooth}
    body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:15px;line-height:1.6}
    ::-webkit-scrollbar{width:5px}
    ::-webkit-scrollbar-track{background:var(--bg)}
    ::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}

    /* ── NAV ── */
    nav{position:sticky;top:0;z-index:200;background:rgba(13,19,33,.95);backdrop-filter:blur(16px);
      border-bottom:1px solid var(--border);padding:0 2rem;display:flex;align-items:center;
      justify-content:space-between;height:64px;gap:1rem}
    .nav-logo{font-family:'Playfair Display',serif;font-size:1.1rem;color:var(--gold2);letter-spacing:.02em;white-space:nowrap}
    .nav-links{display:flex;gap:4px;flex-wrap:wrap}
    .nav-links button{background:none;border:1px solid transparent;border-radius:var(--radius);
      padding:7px 16px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;
      color:var(--muted);cursor:pointer;transition:all .2s}
    .nav-links button:hover{background:var(--surface2);color:var(--text)}
    .nav-links button.active{background:var(--gold-bg);border-color:var(--gold-border);color:var(--gold2)}
    .nav-right{display:flex;align-items:center;gap:8px}
    .lock-btn{background:var(--surface2);border:1px solid var(--border2);border-radius:var(--radius);
      padding:6px 14px;font-family:'Inter',sans-serif;font-size:12px;font-weight:500;
      color:var(--muted);cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:5px}
    .lock-btn:hover{border-color:var(--gold-border);color:var(--gold2)}
    .lock-btn.unlocked{border-color:var(--gold-border);color:var(--gold2);background:var(--gold-bg)}

    /* ── LAYOUT ── */
    .site{max-width:960px;margin:0 auto;padding:3rem 1.5rem 5rem}
    .page{display:none}
    .page.visible{display:block;animation:fadeUp .3s ease}
    @keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}

    /* ── HERO ── */
    .hero{position:relative;overflow:hidden;display:grid;grid-template-columns:1fr auto;
      gap:2.5rem;align-items:center;background:var(--surface);border:1px solid var(--border);
      border-radius:var(--radius-xl);padding:3rem;margin-bottom:2.5rem}
    .hero::before{content:'';position:absolute;top:-80px;right:-80px;width:340px;height:340px;
      background:radial-gradient(circle,rgba(116,140,171,.12) 0%,transparent 70%);pointer-events:none}
    .hero-school{font-size:11px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;
      color:var(--accent);margin-bottom:.7rem}
    .hero h1{font-family:'Playfair Display',serif;font-size:2.8rem;line-height:1.05;
      color:var(--text);margin-bottom:.8rem}
    .hero-bio{font-size:14px;line-height:1.85;color:var(--muted);max-width:400px}
    .skills-row{display:flex;flex-wrap:wrap;gap:7px;margin-top:1.2rem}
    .skill-tag{background:var(--surface3);color:var(--muted);border:1px solid var(--border2);
      border-radius:20px;padding:4px 14px;font-size:12px;font-weight:500;transition:all .2s}
    .skill-tag:hover{border-color:var(--gold-border);color:var(--gold2)}
    .avatar-wrap{flex-shrink:0}
    .avatar-img{width:130px;height:130px;border-radius:50%;object-fit:cover;
      border:3px solid var(--border2);display:block;transition:border-color .2s}
    .avatar-img:hover{border-color:var(--accent)}
    .avatar-initials{width:130px;height:130px;background:var(--surface3);
      border:2px solid var(--border2);border-radius:50%;display:flex;
      align-items:center;justify-content:center;
      font-family:'Playfair Display',serif;font-size:2.2rem;color:var(--gold2);flex-shrink:0}
    .edit-hero-btn{position:absolute;top:1.2rem;right:1.2rem;background:var(--surface3);
      border:1px solid var(--border);border-radius:var(--radius);padding:6px 14px;
      font-family:'Inter',sans-serif;font-size:12px;font-weight:500;color:var(--muted);
      cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:5px}
    .edit-hero-btn:hover{border-color:var(--gold-border);color:var(--gold2)}
    .owner-only{display:none}
    body.owner-mode .owner-only{display:flex}

    /* ── MODAL ── */
    .modal-overlay{display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.75);
      backdrop-filter:blur(6px);align-items:center;justify-content:center;padding:1rem}
    .modal-overlay.open{display:flex;animation:fadeUp .22s ease}
    .modal-box{background:var(--surface);border:1px solid var(--border2);
      border-radius:var(--radius-xl);padding:2rem;width:100%;max-width:540px;
      max-height:90vh;overflow-y:auto}
    .modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem}
    .modal-title{font-family:'Playfair Display',serif;font-size:1.3rem;color:var(--text)}
    .modal-close{background:none;border:none;font-size:22px;color:var(--hint);cursor:pointer;
      transition:color .15s;line-height:1}
    .modal-close:hover{color:var(--text)}

    /* ── AUTH MODAL ── */
    .auth-modal{max-width:380px}
    .auth-title{font-size:1rem;font-weight:600;color:var(--text);margin-bottom:.5rem}
    .auth-sub{font-size:13px;color:var(--muted);margin-bottom:1.2rem}
    .pin-row{display:flex;gap:8px;margin-bottom:1rem}
    .pin-dot{width:44px;height:56px;background:var(--bg2);border:1px solid var(--border2);
      border-radius:var(--radius);display:flex;align-items:center;justify-content:center;
      font-size:1.4rem;transition:border-color .15s;font-family:'Inter',sans-serif}
    .pin-dot.filled{border-color:var(--accent)}
    .pin-keypad{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
    .pin-key{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);
      padding:14px;font-size:15px;font-weight:500;color:var(--text);cursor:pointer;
      transition:all .18s;font-family:'Inter',sans-serif;text-align:center}
    .pin-key:hover{background:var(--surface3);border-color:var(--border2)}
    .pin-key.del{color:var(--muted)}
    .pin-error{color:var(--red);font-size:12px;text-align:center;margin-top:.5rem;min-height:1rem}

    /* ── STATS ── */
    .stat-bar{display:flex;gap:1rem;margin-bottom:2.5rem;flex-wrap:wrap}
    .stat-card{background:var(--surface);border:1px solid var(--border);
      border-radius:var(--radius-lg);padding:1rem 1.4rem;flex:1;min-width:110px}
    .stat-label{font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;
      color:var(--hint);margin-bottom:.3rem}
    .stat-value{font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--gold2);line-height:1}

    /* ── SECTION ── */
    .section-header{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:1.5rem}
    .section-title{font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--text)}
    .section-sub{font-family:'Playfair Display',serif;font-size:1.1rem;color:var(--text);margin-bottom:1rem}
    .divider{border:none;border-top:1px solid var(--border);margin:2rem 0}

    /* ── WIP BANNER ── */
    .wip-banner{background:rgba(116,140,171,.08);border:1px solid rgba(116,140,171,.25);
      border-radius:var(--radius-lg);padding:1.2rem 1.5rem;margin-bottom:2rem;
      display:flex;align-items:center;gap:12px;color:var(--muted);font-size:13px}
    .wip-dot{width:8px;height:8px;border-radius:50%;background:var(--accent);
      animation:pulse 2s infinite;flex-shrink:0}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

    /* ── HOME & OVERVIEW CARDS ── */
    .projects-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));
      gap:1rem;margin-bottom:2.5rem}
    .proj-card{background:var(--surface);border:1px solid var(--border);
      border-radius:var(--radius-lg);overflow:hidden;
      transition:border-color .2s,transform .2s,box-shadow .2s;cursor:pointer}
    .proj-card:hover{border-color:var(--border2);transform:translateY(-3px);
      box-shadow:0 12px 40px rgba(0,0,0,.5)}
    .proj-img{height:88px;background:var(--surface2);display:flex;align-items:center;
      justify-content:center;font-size:2rem;border-bottom:1px solid var(--border);overflow:hidden}
    .proj-img img{width:100%;height:100%;object-fit:cover}
    .proj-body{padding:1rem 1.1rem 1.15rem}
    .year-badge{display:inline-block;font-size:10px;font-weight:600;letter-spacing:.06em;
      text-transform:uppercase;background:rgba(116,140,171,.12);color:var(--accent2);
      border:1px solid rgba(116,140,171,.3);border-radius:20px;padding:2px 10px;margin-bottom:.55rem}
    .proj-body h3{font-size:14px;font-weight:600;color:var(--text);margin-bottom:.35rem}
    .proj-body p{font-size:13px;color:var(--muted);line-height:1.65}

    /* ── DETAIL PAGE ── */
    #page-detail .detail-back{background:none;border:1px solid var(--border);border-radius:var(--radius);
      padding:7px 16px;font-family:'Inter',sans-serif;font-size:13px;color:var(--muted);
      cursor:pointer;transition:all .2s;margin-bottom:1.5rem;display:inline-flex;align-items:center;gap:6px}
    #page-detail .detail-back:hover{background:var(--surface2);color:var(--text)}
    .detail-hero{background:var(--surface);border:1px solid var(--border);
      border-radius:var(--radius-xl);overflow:hidden;margin-bottom:2rem}
    .detail-cover{height:240px;background:var(--surface2);display:flex;align-items:center;
      justify-content:center;font-size:4rem;overflow:hidden}
    .detail-cover img{width:100%;height:100%;object-fit:cover}
    .detail-body{padding:2rem}
    .detail-title{font-family:'Playfair Display',serif;font-size:2rem;color:var(--text);margin-bottom:.5rem}
    .detail-badges{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:1.2rem}
    .detail-desc{font-size:14px;color:var(--muted);line-height:1.85;margin-bottom:1.5rem}
    .detail-section-label{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;
      color:var(--hint);margin-bottom:.8rem}
    .competenze-grid{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:1.5rem}
    .comp-item{background:var(--surface2);border:1px solid var(--border);
      border-radius:var(--radius);padding:.75rem 1rem;font-size:13px;color:var(--muted)}
    .comp-item strong{display:block;font-size:11px;font-weight:600;color:var(--hint);
      text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
    .detail-gallery{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem}
    .gallery-img{width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:var(--radius);
      border:1px solid var(--border);transition:transform .2s,border-color .2s;cursor:pointer}
    .gallery-img:hover{transform:scale(1.02);border-color:var(--border2)}

    /* ── LIGHTBOX ── */
    .lightbox{display:none;position:fixed;inset:0;z-index:800;background:rgba(0,0,0,.92);
      align-items:center;justify-content:center;padding:1rem}
    .lightbox.open{display:flex}
    .lightbox img{max-width:90vw;max-height:88vh;border-radius:var(--radius-lg);object-fit:contain}
    .lightbox-close{position:absolute;top:1rem;right:1rem;background:none;border:none;
      font-size:28px;color:rgba(255,255,255,.7);cursor:pointer;transition:color .15s}
    .lightbox-close:hover{color:#fff}

    /* ── PRESET CARDS ── */
    .preset-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
      gap:1rem;margin-bottom:2rem}
    .preset-card{background:var(--surface);border:1px solid var(--border);
      border-radius:var(--radius-lg);overflow:hidden;transition:border-color .2s,box-shadow .2s}
    .preset-card:hover{border-color:var(--border2);box-shadow:0 8px 32px rgba(0,0,0,.4)}
    .preset-card-top{padding:.85rem 1rem;background:var(--surface2);
      border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
    .preset-card-icon{font-size:1.35rem}
    .preset-card-actions{display:flex;gap:4px}
    .icon-btn{background:none;border:1px solid transparent;border-radius:8px;padding:4px 8px;
      font-size:13px;color:var(--hint);cursor:pointer;transition:all .18s}
    .icon-btn:hover{background:var(--surface3);color:var(--text);border-color:var(--border)}
    .icon-btn.danger:hover{color:var(--red);border-color:rgba(224,92,92,.4)}
    .icon-btn.view-btn{color:var(--accent)}
    .icon-btn.view-btn:hover{color:var(--gold2);border-color:var(--gold-border)}
    .preset-card-body{padding:.9rem 1rem}
    .preset-card-name{font-size:14px;font-weight:600;color:var(--text);margin-bottom:.3rem}
    .preset-card-desc{font-size:12px;color:var(--muted);line-height:1.65}
    .preset-card-meta{display:flex;gap:6px;flex-wrap:wrap;margin-top:.7rem}
    .meta-chip{font-size:11px;font-weight:500;background:var(--surface3);color:var(--hint);
      border:1px solid var(--border);border-radius:20px;padding:2px 10px}
    .meta-chip.gold{background:var(--gold-bg);color:var(--gold);border-color:var(--gold-border)}

    /* ── EDIT INLINE ── */
    .edit-inline{display:none;padding:1rem;border-top:1px solid var(--border);background:var(--bg2)}
    .edit-inline.open{display:block}

    /* ── ADDED LIST ── */
    .proj-list{display:flex;flex-direction:column;gap:.8rem;margin-bottom:1.5rem}
    .proj-item{background:var(--surface);border:1px solid var(--border);
      border-radius:var(--radius-lg);overflow:hidden;animation:slideDown .22s ease;cursor:pointer;
      transition:border-color .2s}
    .proj-item:hover{border-color:var(--border2)}
    @keyframes slideDown{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:none}}
    .proj-item-top{padding:.9rem 1rem;background:var(--surface2);
      border-bottom:1px solid var(--border);display:flex;align-items:center;
      justify-content:space-between;gap:.5rem}
    .proj-item-info{flex:1;min-width:0}
    .proj-item-title{font-size:14px;font-weight:600;color:var(--text);margin-bottom:2px}
    .proj-item-sub{font-size:12px;color:var(--hint)}
    .proj-item-badges{display:flex;gap:6px;align-items:center;flex-shrink:0}
    .proj-item-body{padding:.8rem 1rem}
    .proj-item-desc{font-size:13px;color:var(--muted);line-height:1.7}
    .ore-badge{font-size:11px;font-weight:600;background:var(--gold-bg);color:var(--gold);
      border:1px solid var(--gold-border);border-radius:20px;padding:2px 10px}
    .date-badge{font-size:11px;color:var(--hint)}


    /* ── FORM ── */
    .form-section{background:var(--surface);border:1px solid var(--border);
      border-radius:var(--radius-lg);overflow:hidden;margin-bottom:2rem}
    .form-header{padding:1.1rem 1.5rem;background:var(--surface2);
      border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
    .form-header-icon{width:28px;height:28px;background:var(--gold-bg);
      border:1px solid var(--gold-border);border-radius:8px;display:flex;
      align-items:center;justify-content:center;font-size:14px;color:var(--gold);font-weight:600}
    .form-title{font-size:14px;font-weight:600;color:var(--text)}
    .form-body{padding:1.5rem}
    .form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem}
    .form-group{display:flex;flex-direction:column;gap:5px}
    .form-group.full{grid-column:1/-1}
    label{font-size:11px;font-weight:600;color:var(--hint);text-transform:uppercase;letter-spacing:.06em}
    input[type=text],input[type=date],input[type=password],textarea{
      width:100%;padding:9px 12px;font-family:'Inter',sans-serif;font-size:14px;
      border:1px solid var(--border);border-radius:var(--radius);background:var(--bg2);
      color:var(--text);transition:border-color .15s,box-shadow .15s;outline:none}
    input:focus,textarea:focus{border-color:rgba(116,140,171,.5);
      box-shadow:0 0 0 3px rgba(116,140,171,.07)}
    input::placeholder,textarea::placeholder{color:var(--hint)}
    textarea{resize:vertical;min-height:80px;line-height:1.6}
    input[type=date]::-webkit-calendar-picker-indicator{filter:invert(.4)}
    .save-btn{width:100%;padding:11px;margin-top:.25rem;background:var(--surface3);
      color:var(--text);border:1px solid var(--border2);border-radius:var(--radius);
      font-family:'Inter',sans-serif;font-size:14px;font-weight:600;cursor:pointer;
      transition:all .2s}
    .save-btn:hover{background:var(--surface2);border-color:var(--accent)}
    .cancel-btn{width:100%;padding:9px;margin-top:.5rem;background:none;color:var(--hint);
      border:1px solid var(--border);border-radius:var(--radius);font-family:'Inter',sans-serif;
      font-size:13px;font-weight:500;cursor:pointer;transition:all .18s}
    .cancel-btn:hover{border-color:var(--border2);color:var(--text)}

    /* owner-only edit items */
    .owner-only-inline{display:none}
    body.owner-mode .owner-only-inline{display:flex}

    /* ── TOAST ── */
    #toast{position:fixed;bottom:1.8rem;right:1.8rem;display:flex;align-items:center;gap:8px;
      background:var(--surface);border:1px solid var(--border2);color:var(--text);
      padding:12px 18px;border-radius:var(--radius-lg);font-size:13px;font-weight:500;
      opacity:0;pointer-events:none;transform:translateY(8px);
      transition:opacity .28s,transform .28s;z-index:999;box-shadow:0 10px 40px rgba(0,0,0,.6)}
    #toast.show{opacity:1;transform:none}
    .toast-dot{width:8px;height:8px;border-radius:50%;background:var(--green);flex-shrink:0}

    /* ── FOOTER ── */
    footer{text-align:center;padding:2.5rem 1rem;font-size:12px;color:var(--hint);
      border-top:1px solid var(--border)}
    footer span{color:var(--accent2)}

    /* ── RESPONSIVE ── */
    @media(max-width:640px){
      .hero{grid-template-columns:1fr;padding:2rem 1.5rem}
      .avatar-wrap{display:none}
      .form-row{grid-template-columns:1fr}
      nav{padding:0 1rem}
      .nav-links button{padding:7px 11px;font-size:12px}
      .hero h1{font-size:2.2rem}
      .competenze-grid{grid-template-columns:1fr}
    }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <span class="nav-logo">Portfolio PCTO</span>
  <div class="nav-links">
    <button class="active" data-page="home">Home</button>
    <button data-page="terza">Terza</button>
    <button data-page="quarta">Quarta</button>
    <button data-page="quinta">Quinta</button>
  </div>
  <div class="nav-right">
    <button class="lock-btn" id="lock-btn">🔒 Proprietario</button>
  </div>
</nav>

<!-- AUTH MODAL -->
<div class="modal-overlay" id="modal-auth">
  <div class="modal-box auth-modal">
    <div class="modal-header">
      <span class="modal-title">Accesso proprietario</span>
      <button class="modal-close" id="auth-close">×</button>
    </div>
    <div class="auth-title" id="auth-mode-title">Inserisci PIN</div>
    <div class="auth-sub" id="auth-mode-sub">Inserisci il PIN a 4 cifre per modificare il portfolio.</div>
    <div class="pin-row" id="pin-display">
      <div class="pin-dot" id="pd0">·</div>
      <div class="pin-dot" id="pd1">·</div>
      <div class="pin-dot" id="pd2">·</div>
      <div class="pin-dot" id="pd3">·</div>
    </div>
    <div class="pin-keypad">
      <button class="pin-key" data-d="1">1</button>
      <button class="pin-key" data-d="2">2</button>
      <button class="pin-key" data-d="3">3</button>
      <button class="pin-key" data-d="4">4</button>
      <button class="pin-key" data-d="5">5</button>
      <button class="pin-key" data-d="6">6</button>
      <button class="pin-key" data-d="7">7</button>
      <button class="pin-key" data-d="8">8</button>
      <button class="pin-key" data-d="9">9</button>
      <button class="pin-key" data-d="0" style="grid-column:2">0</button>
      <button class="pin-key del" id="pin-del">⌫</button>
    </div>
    <div class="pin-error" id="pin-error"></div>
  </div>
</div>

<!-- MODAL ABOUT ME -->
<div class="modal-overlay" id="modal-about">
  <div class="modal-box">
