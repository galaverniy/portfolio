function renderAddedList(year){
  var $list=$('#list-'+year).empty();
  if(!added[year].length){
    return;
  }
  $.each(added[year],function(i,proj){
    var ore  =proj.ore ?'<span class="ore-badge">'+esc(proj.ore)+'h</span>':'';
    var dt   =proj.date?'<span class="date-badge">'+fmtDate(proj.date)+'</span>':'';
    var ente =proj.ente?'<div class="proj-item-sub">'+esc(proj.ente)+'</div>':'';
    var desc =proj.desc?'<div class="proj-item-body"><div class="proj-item-desc">'+esc(proj.desc)+'</div></div>':'';
    $list.append(
      '<div class="proj-item" data-year="'+year+'" data-idx="'+i+'">'+
        '<div class="proj-item-top">'+
          '<div class="proj-item-info"><div class="proj-item-title">'+esc(proj.name)+'</div>'+ente+'</div>'+
          '<div class="proj-item-badges">'+dt+ore+
            '<button class="icon-btn view-btn added-view-btn" data-year="'+year+'" data-idx="'+i+'" title="Dettagli">👁</button>'+
            '<button class="icon-btn added-edit-btn owner-only-inline" data-year="'+year+'" data-idx="'+i+'" title="Modifica">✏️</button>'+
            '<button class="icon-btn danger added-del-btn owner-only-inline" data-year="'+year+'" data-idx="'+i+'" title="Elimina">🗑</button>'+
          '</div>'+
        '</div>'+
        desc+
        '<div class="edit-inline" id="ei-a-'+year+'-'+i+'">'+addedEditHtml(year,i,proj)+'</div>'+
      '</div>'
    );
  });
}

